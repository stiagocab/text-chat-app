{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API (Auto Restart)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "nodemon",
      "program": "${workspaceFolder}/src/index.ts",
      "restart": true,
      "runtimeArgs": [
        "--exec",
        "node -r ts-node/register -r tsconfig-paths/register"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}