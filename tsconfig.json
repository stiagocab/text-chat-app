{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "isolatedModules": true,
    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": "./src",

    "paths": {
      "routes/*": ["routes/*"],
      "controllers/*": ["controllers/*"],
      "services/*": ["services/*"],
      "models/*": ["models/*"],
      "utils/*": ["utils/*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*", "tsconfig.json"]
}
